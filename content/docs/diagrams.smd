<!--

Diagram(
  Start("complex"), 
Group(
  Optional(
    MultipleChoice(2, "any",
      Comment('newline'),
      Comment('tab'),
      Comment('space'),
      NonTerminal('comment')
    ) 
  ),
  'no whitespace'
),
  End('complex')
)


-->
```
