<path d="M236 108h0"></path>
<path d="M50 108a10 10 0 0 0 10 -10v-44a10 10 0 0 1 10 -10"></path>
<g>
<path d="M70 44h146"></path>
</g>
<path d="M216 44a10 10 0 0 1 10 10v44a10 10 0 0 0 10 10"></path>
<path d="M50 108h20"></path>
<g>
<path d="M70 108h0"></path>
<path d="M216 108h0"></path>
<path d="M100 108v-14a10 10 0 0 1 10 -10"></path>
<g class="comment ">
<path d="M110 84h22.5"></path>
<path d="M163.5 84h22.5"></path>
<text x="148" y="89" class="comment">tab</text>
</g>
<path d="M186 84a10 10 0 0 1 10 10v4"></path>
