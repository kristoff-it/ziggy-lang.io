<text x="148" y="65" class="comment">newline</text>
</g>
<path d="M186 60a10 10 0 0 1 10 10v28"></path>
<path d="M100 108h10"></path>
<g class="comment ">
<path d="M110 108h15.5"></path>
<path d="M170.5 108h15.5"></path>
<text x="148" y="113" class="comment">space</text>
</g>
<path d="M186 108h10"></path>
