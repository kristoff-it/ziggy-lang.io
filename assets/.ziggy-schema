$ = {:}Diagram

struct Diagram {
    delimiters: ?Delimiters,
    /// Show the diagram's name inside the diagram itself
    label: ?bool,
    alignment: ?Alignment,
    description: ?bytes,
    body: []Item,

    union Delimiters {
        pipes,
        directional,
    }

    union Alignment {
        left,
        center,
        right,
    }
}

union Item {
    /// A terminal in a grammar, i.e. literal text that matches a rule.
    terminal: bytes,
    /// A reference to another production (i.e. another diagram).
    /// The value must be the name of another diagram in this file.
    reference: bytes,
    /// Represents an instruction or a reference to an external diagram.
    /// An example could be a reference to unicode or a list of letters.
    external: bytes,
    /// A comment that renders at the line level.
    inline_comment: bytes,
    /// An empty line.
    skip,
    /// Adds a comment label above an item.
    label: Label,
    /// A comment that renders above the line level. It's a shortcut for
    /// creating a label over a skip.
    label_path: bytes,
    /// Highlights its child with a dashed outline, and optionally labels it.
    group: Group,
    /// A concatenation of items.
    sequence: []Item,
    /// Identical to a `sequence`, but the items are stacked vertically
    /// rather than horizontally.
    ///
    /// Useful to break long sequences into multiple, vertically-stacked,
    /// sub-sequences.
    sequence_stack: []Item,
    /// A sequence where every item is individually optional, but at least
    /// one item must be chosen
    sequence_optional: []Item,
    /// An alternating sequence of two possible items.
    sequence_alternating: AlternatingSequence,
    /// A choce represents a branching point where only one of the listed
    /// items chan be chosen. Puts the first item on the straight line.
    choice: []Item,
    /// Same as `choice` but it puts the center element on the straight line.
    /// Requires an odd number of items.
    ///
    /// Use `choice_index` when dealing with an even number.
    choice_middle: []Item,
    /// Same as `choice`, but it puts the last element on the straight line.
    ///
    /// Use `choice_index` for more fine-grained control over element positioning.
    choice_last: []Item,
    /// Same as `choice`, but the items are stacked horizontally rather
    /// than vertically. There's no "straight-line" choice, so it just
    /// takes a list of children.
    ///
    /// Useful to split a single (tall) choice into shorter "sub-choices"
    /// stacked horizontally.
    choice_horizontal: []Item,
    /// Same as `choice`, takes an index for more fine-grainded control
    /// of item positioning.
    choice_index: ChoiceIndex,
    /// Expresses the ability to choose the order in which to select the
    /// items, but implies that each item can only be used once (i.e. it
    /// gets "consumed").
    multiple_choice_any: ChoiceIndex,
    /// Same as `multiple_choice_any`, but additionally requires that all
    /// items be consumed before leaving.
    multiple_choice_all: ChoiceIndex,
    /// When the same item can be selected multiple times in a row.
    repeat: Item,
    /// Same as `repeat` but also lets you specify a separator item
    repeat_separator: RepeatSeparator,

    struct Label {
        label: bytes,
        item: Item,
    }

    struct ChoiceIndex {
        /// Specifies which child is the straight-line choice in the middle.
        index: int,
        items: []Item,
    }

    struct RepeatSeparator {
        item: Item,
        separator: ?Item,
    }

    struct Group {
        label: ?bytes,
        item: Item,
    }

    struct AlternatingSequence {
        first: Item,
        second: Item,
    }
}
